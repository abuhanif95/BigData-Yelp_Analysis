{"paragraphs":[{"text":"%pyspark\r\n\r\nfrom pyspark.sql.functions import *\r\nfrom pyspark.sql.types import *\r\n\r\n# Load weather data\r\nweather_df = spark.read \\\r\n    .option(\"header\", \"true\") \\\r\n    .option(\"inferSchema\", \"true\") \\\r\n    .csv(\"/user/shirsha/weather/usa_*.csv\")\r\n\r\n# Clean and convert weather data\r\nweather_clean = weather_df \\\r\n    .withColumnRenamed(\"DATE\", \"weather_date\") \\\r\n    .withColumn(\"temp_max_f\", col(\"TMAX\") / 10) \\\r\n    .withColumn(\"temp_min_f\", col(\"TMIN\") / 10) \\\r\n    .withColumn(\"temp_avg_f\", col(\"TAVG\") / 10) \\\r\n    .withColumn(\"precipitation_in\", col(\"PRCP\") / 10) \\\r\n    .withColumn(\"wind_speed\", col(\"AWND\")) \\\r\n    .select(\"weather_date\", \"temp_max_f\", \"temp_min_f\", \"temp_avg_f\", \"precipitation_in\", \"wind_speed\") \\\r\n    .filter(col(\"weather_date\").isNotNull())\r\n\r\n# Create Hive table\r\nweather_clean.write.mode(\"overwrite\").saveAsTable(\"weather_data\")\r\n\r\nprint(f\"Weather data loaded: {weather_clean.count()} records\")\r\nspark.sql(\"SELECT * FROM weather_data LIMIT 5\").show()","user":"anonymous","dateUpdated":"2026-03-26T15:33:00+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Hive Session ID = 16e768a5-194b-490e-be8a-f1a87fe1fe25\nWeather data loaded: 158753 records\n+------------+----------+----------+----------+----------------+----------+\n|weather_date|temp_max_f|temp_min_f|temp_avg_f|precipitation_in|wind_speed|\n+------------+----------+----------+----------+----------------+----------+\n|  2017-01-01|      NULL|      NULL|      NULL|             0.0|      NULL|\n|  2017-01-02|      NULL|      NULL|      NULL|            0.38|      NULL|\n|  2017-01-03|      NULL|      NULL|      NULL|            1.47|      NULL|\n|  2017-01-04|      NULL|      NULL|      NULL|            0.71|      NULL|\n|  2017-01-05|      NULL|      NULL|      NULL|             0.0|      NULL|\n+------------+----------+----------+----------+----------------+----------+\n\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=106"},{"jobUrl":"http://node-master:4040/jobs/job?id=107"},{"jobUrl":"http://node-master:4040/jobs/job?id=108"},{"jobUrl":"http://node-master:4040/jobs/job?id=109"},{"jobUrl":"http://node-master:4040/jobs/job?id=110"},{"jobUrl":"http://node-master:4040/jobs/job?id=111"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774510350616_576716255","id":"paragraph_1774510350616_576716255","dateCreated":"2026-03-26T15:32:30+0800","dateStarted":"2026-03-26T15:33:00+0800","dateFinished":"2026-03-26T15:35:15+0800","status":"FINISHED","focus":false},{"text":"%pyspark\n\n# Filter out records with NULL temperatures\nweather_clean_complete = weather_clean \\\n    .filter(col(\"temp_max_f\").isNotNull()) \\\n    .filter(col(\"temp_min_f\").isNotNull())\n\nprint(f\"Complete weather records: {weather_clean_complete.count()}\")\n\n# Check date range\nweather_clean_complete.select(min(\"weather_date\"), max(\"weather_date\")).show()\n\n# View sample of clean data\nweather_clean_complete.limit(10).show()","user":"anonymous","dateUpdated":"2026-03-26T15:38:24+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Complete weather records: 142815\n+-----------------+-----------------+\n|min(weather_date)|max(weather_date)|\n+-----------------+-----------------+\n|       2017-01-01|       2022-12-31|\n+-----------------+-----------------+\n\n+------------+--------------------+-------------------+----------+----------------+----------+\n|weather_date|          temp_max_f|         temp_min_f|temp_avg_f|precipitation_in|wind_speed|\n+------------+--------------------+-------------------+----------+----------------+----------+\n|  2017-01-01|  0.8300000000000001|               0.39|      NULL|            0.64|      NULL|\n|  2017-01-02|                1.28| 0.8300000000000001|      NULL|            0.15|      NULL|\n|  2017-01-03|                1.89|               1.28|      NULL|            1.78|      NULL|\n|  2017-01-04|                1.83|                0.0|      NULL|            0.25|      NULL|\n|  2017-01-05|                0.39|              -0.39|      NULL|             0.0|      NULL|\n|  2017-01-06|                 0.0|              -0.72|      NULL|             0.0|      NULL|\n|  2017-01-07|                -0.5|              -1.17|      NULL|             0.0|      NULL|\n|  2017-01-08| -0.5599999999999999|              -1.44|      NULL|             0.0|      NULL|\n|  2017-01-09|-0.16999999999999998|-1.3900000000000001|      NULL|             0.0|      NULL|\n|  2017-01-10|                0.78|              -0.39|      NULL|             0.0|      NULL|\n+------------+--------------------+-------------------+----------+----------------+----------+\n\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=112"},{"jobUrl":"http://node-master:4040/jobs/job?id=113"},{"jobUrl":"http://node-master:4040/jobs/job?id=114"},{"jobUrl":"http://node-master:4040/jobs/job?id=115"},{"jobUrl":"http://node-master:4040/jobs/job?id=116"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774510380162_1371704966","id":"paragraph_1774510380162_1371704966","dateCreated":"2026-03-26T15:33:00+0800","dateStarted":"2026-03-26T15:38:25+0800","dateFinished":"2026-03-26T15:38:37+0800","status":"FINISHED"},{"text":"%pyspark\n\n# Re-load and convert correctly\nweather_df = spark.read \\\n    .option(\"header\", \"true\") \\\n    .option(\"inferSchema\", \"true\") \\\n    .csv(\"/user/shirsha/weather/usa_*.csv\")\n\n# Convert correctly: from tenths of Celsius to Fahrenheit\nweather_clean = weather_df \\\n    .withColumnRenamed(\"DATE\", \"weather_date\") \\\n    .withColumn(\"temp_c_max\", col(\"TMAX\") / 10) \\\n    .withColumn(\"temp_c_min\", col(\"TMIN\") / 10) \\\n    .withColumn(\"temp_c_avg\", col(\"TAVG\") / 10) \\\n    .withColumn(\"temp_max_f\", (col(\"temp_c_max\") * 9/5) + 32) \\\n    .withColumn(\"temp_min_f\", (col(\"temp_c_min\") * 9/5) + 32) \\\n    .withColumn(\"temp_avg_f\", (col(\"temp_c_avg\") * 9/5) + 32) \\\n    .withColumn(\"precipitation_in\", col(\"PRCP\") / 10) \\\n    .withColumn(\"wind_speed\", col(\"AWND\")) \\\n    .select(\"weather_date\", \"temp_max_f\", \"temp_min_f\", \"temp_avg_f\", \"precipitation_in\", \"wind_speed\") \\\n    .filter(col(\"weather_date\").isNotNull()) \\\n    .filter(col(\"temp_max_f\").isNotNull())\n\n# Save to table\nweather_clean.write.mode(\"overwrite\").saveAsTable(\"weather_data\")\n\nprint(f\"Weather data loaded: {weather_clean.count()} records\")\nprint(\"\\nSample with correct Fahrenheit temperatures:\")\nspark.sql(\"SELECT * FROM weather_data LIMIT 10\").show()","user":"anonymous","dateUpdated":"2026-03-26T15:40:20+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Weather data loaded: 143264 records\n\nSample with correct Fahrenheit temperatures:\n+------------+----------+----------+----------+----------------+----------+\n|weather_date|temp_max_f|temp_min_f|temp_avg_f|precipitation_in|wind_speed|\n+------------+----------+----------+----------+----------------+----------+\n|  2017-01-01|    33.494|    32.702|      NULL|            0.64|      NULL|\n|  2017-01-02|    34.304|    33.494|      NULL|            0.15|      NULL|\n|  2017-01-03|    35.402|    34.304|      NULL|            1.78|      NULL|\n|  2017-01-04|    35.294|      32.0|      NULL|            0.25|      NULL|\n|  2017-01-05|    32.702|    31.298|      NULL|             0.0|      NULL|\n|  2017-01-06|      32.0|    30.704|      NULL|             0.0|      NULL|\n|  2017-01-07|      31.1|    29.894|      NULL|             0.0|      NULL|\n|  2017-01-08|    30.992|    29.408|      NULL|             0.0|      NULL|\n|  2017-01-09|    31.694|    29.498|      NULL|             0.0|      NULL|\n|  2017-01-10|    33.404|    31.298|      NULL|             0.0|      NULL|\n+------------+----------+----------+----------+----------------+----------+\n\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=117"},{"jobUrl":"http://node-master:4040/jobs/job?id=118"},{"jobUrl":"http://node-master:4040/jobs/job?id=119"},{"jobUrl":"http://node-master:4040/jobs/job?id=120"},{"jobUrl":"http://node-master:4040/jobs/job?id=121"},{"jobUrl":"http://node-master:4040/jobs/job?id=122"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774510704997_1386014487","id":"paragraph_1774510704997_1386014487","dateCreated":"2026-03-26T15:38:24+0800","dateStarted":"2026-03-26T15:40:20+0800","dateFinished":"2026-03-26T15:40:59+0800","status":"FINISHED"},{"text":"%pyspark\n\n# Check all cities in your list\ncities_data = [\n    (\"Philadelphia\", \"PA\"),\n    (\"Tampa\", \"FL\"),\n    (\"Indianapolis\", \"IN\"),\n    (\"Nashville\", \"TN\"),\n    (\"Tucson\", \"AZ\"),\n    (\"New Orleans\", \"LA\"),\n    (\"St. Petersburg\", \"FL\"),\n    (\"Reno\", \"NV\"),\n    (\"Santa Barbara\", \"CA\"),\n    (\"Boise\", \"ID\"),\n    (\"St. Louis\", \"MO\")\n]\n\nprint(\"City Business Counts:\")\nprint(\"-\" * 40)\n\nfor city, state in cities_data:\n    count = spark.sql(f\"\"\"\n        SELECT COUNT(*) as cnt \n        FROM yelp_business \n        WHERE city = '{city}' AND state = '{state}'\n    \"\"\").collect()[0][0]\n    \n    # Also get review count\n    review_count = spark.sql(f\"\"\"\n        SELECT SUM(review_count) as total_reviews\n        FROM yelp_business \n        WHERE city = '{city}' AND state = '{state}'\n    \"\"\").collect()[0][0] or 0\n    \n    print(f\"{city}, {state}: {count:,} businesses, {review_count:,} reviews\")","user":"anonymous","dateUpdated":"2026-03-26T15:42:13+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"City Business Counts:\n----------------------------------------\nPhiladelphia, PA: 14,567 businesses, 936,207 reviews\nTampa, FL: 9,048 businesses, 439,450 reviews\nIndianapolis, IN: 7,540 businesses, 349,228 reviews\nNashville, TN: 6,968 businesses, 440,988 reviews\nTucson, AZ: 9,249 businesses, 387,239 reviews\nNew Orleans, LA: 6,208 businesses, 621,330 reviews\nSt. Petersburg, FL: 1,185 businesses, 52,620 reviews\nReno, NV: 5,932 businesses, 334,555 reviews\nSanta Barbara, CA: 3,829 businesses, 262,853 reviews\nBoise, ID: 2,937 businesses, 101,893 reviews\nSt. Louis, MO: 1,254 businesses, 61,256 reviews\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=123"},{"jobUrl":"http://node-master:4040/jobs/job?id=124"},{"jobUrl":"http://node-master:4040/jobs/job?id=125"},{"jobUrl":"http://node-master:4040/jobs/job?id=126"},{"jobUrl":"http://node-master:4040/jobs/job?id=127"},{"jobUrl":"http://node-master:4040/jobs/job?id=128"},{"jobUrl":"http://node-master:4040/jobs/job?id=129"},{"jobUrl":"http://node-master:4040/jobs/job?id=130"},{"jobUrl":"http://node-master:4040/jobs/job?id=131"},{"jobUrl":"http://node-master:4040/jobs/job?id=132"},{"jobUrl":"http://node-master:4040/jobs/job?id=133"},{"jobUrl":"http://node-master:4040/jobs/job?id=134"},{"jobUrl":"http://node-master:4040/jobs/job?id=135"},{"jobUrl":"http://node-master:4040/jobs/job?id=136"},{"jobUrl":"http://node-master:4040/jobs/job?id=137"},{"jobUrl":"http://node-master:4040/jobs/job?id=138"},{"jobUrl":"http://node-master:4040/jobs/job?id=139"},{"jobUrl":"http://node-master:4040/jobs/job?id=140"},{"jobUrl":"http://node-master:4040/jobs/job?id=141"},{"jobUrl":"http://node-master:4040/jobs/job?id=142"},{"jobUrl":"http://node-master:4040/jobs/job?id=143"},{"jobUrl":"http://node-master:4040/jobs/job?id=144"},{"jobUrl":"http://node-master:4040/jobs/job?id=145"},{"jobUrl":"http://node-master:4040/jobs/job?id=146"},{"jobUrl":"http://node-master:4040/jobs/job?id=147"},{"jobUrl":"http://node-master:4040/jobs/job?id=148"},{"jobUrl":"http://node-master:4040/jobs/job?id=149"},{"jobUrl":"http://node-master:4040/jobs/job?id=150"},{"jobUrl":"http://node-master:4040/jobs/job?id=151"},{"jobUrl":"http://node-master:4040/jobs/job?id=152"},{"jobUrl":"http://node-master:4040/jobs/job?id=153"},{"jobUrl":"http://node-master:4040/jobs/job?id=154"},{"jobUrl":"http://node-master:4040/jobs/job?id=155"},{"jobUrl":"http://node-master:4040/jobs/job?id=156"},{"jobUrl":"http://node-master:4040/jobs/job?id=157"},{"jobUrl":"http://node-master:4040/jobs/job?id=158"},{"jobUrl":"http://node-master:4040/jobs/job?id=159"},{"jobUrl":"http://node-master:4040/jobs/job?id=160"},{"jobUrl":"http://node-master:4040/jobs/job?id=161"},{"jobUrl":"http://node-master:4040/jobs/job?id=162"},{"jobUrl":"http://node-master:4040/jobs/job?id=163"},{"jobUrl":"http://node-master:4040/jobs/job?id=164"},{"jobUrl":"http://node-master:4040/jobs/job?id=165"},{"jobUrl":"http://node-master:4040/jobs/job?id=166"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774510820858_1734169955","id":"paragraph_1774510820858_1734169955","dateCreated":"2026-03-26T15:40:20+0800","dateStarted":"2026-03-26T15:42:13+0800","dateFinished":"2026-03-26T15:43:15+0800","status":"FINISHED"},{"text":"%pyspark\n\nfrom pyspark.sql.functions import *\n\n# Define all cities\nall_cities = [\n    (\"Philadelphia\", \"PA\"),\n    (\"Tampa\", \"FL\"),\n    (\"Indianapolis\", \"IN\"),\n    (\"Nashville\", \"TN\"),\n    (\"Tucson\", \"AZ\"),\n    (\"New Orleans\", \"LA\"),\n    (\"St. Petersburg\", \"FL\"),\n    (\"Reno\", \"NV\"),\n    (\"Santa Barbara\", \"CA\"),\n    (\"Boise\", \"ID\"),\n    (\"St. Louis\", \"MO\")\n]\n\n# Create empty list to store results\nall_city_reviews = []\n\nfor city, state in all_cities:\n    print(f\"Processing {city}, {state}...\")\n    \n    # Get daily reviews for this city\n    daily_reviews = spark.sql(f\"\"\"\n        SELECT \n            '{city}' as city,\n            '{state}' as state,\n            r.date as review_date,\n            COUNT(*) as total_reviews,\n            AVG(r.stars) as avg_rating,\n            SUM(CASE WHEN r.stars = 1 THEN 1 ELSE 0 END) as one_star_count,\n            SUM(CASE WHEN r.stars = 5 THEN 1 ELSE 0 END) as five_star_count\n        FROM yelp_review r\n        WHERE r.business_id IN (\n            SELECT business_id \n            FROM yelp_business \n            WHERE city = '{city}' AND state = '{state}'\n        )\n        GROUP BY r.date\n    \"\"\")\n    \n    all_city_reviews.append(daily_reviews)\n\n# Union all cities\nall_reviews = all_city_reviews[0]\nfor df in all_city_reviews[1:]:\n    all_reviews = all_reviews.union(df)\n\n# Save to table\nall_reviews.write.mode(\"overwrite\").saveAsTable(\"all_cities_daily_reviews\")\n\nprint(f\"\\nTotal records: {all_reviews.count()}\")\nall_reviews.limit(20).show()","user":"anonymous","dateUpdated":"2026-03-26T15:45:33+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Processing Philadelphia, PA...\nProcessing Tampa, FL...\nProcessing Indianapolis, IN...\nProcessing Nashville, TN...\nProcessing Tucson, AZ...\nProcessing New Orleans, LA...\nProcessing St. Petersburg, FL...\nProcessing Reno, NV...\nProcessing Santa Barbara, CA...\nProcessing Boise, ID...\nProcessing St. Louis, MO...\n\nTotal records: 4113463\n+------------+-----+-------------------+-------------+----------+--------------+---------------+\n|        city|state|        review_date|total_reviews|avg_rating|one_star_count|five_star_count|\n+------------+-----+-------------------+-------------+----------+--------------+---------------+\n|Philadelphia|   PA|2015-03-19 01:04:51|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2010-08-21 21:04:13|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2017-03-12 22:54:19|            1|       2.0|             0|              0|\n|Philadelphia|   PA|2008-05-02 14:30:16|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2014-02-24 12:10:26|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2011-08-25 17:46:26|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2017-10-11 15:37:03|            1|       2.0|             0|              0|\n|Philadelphia|   PA|2018-03-16 23:56:19|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2012-07-16 17:02:57|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2017-08-29 03:14:43|            1|       1.0|             1|              0|\n|Philadelphia|   PA|2017-10-12 00:52:33|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2013-10-24 15:44:45|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2011-03-21 01:58:24|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2017-10-27 00:02:11|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2011-01-10 20:44:08|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2014-04-21 22:09:44|            1|       1.0|             1|              0|\n|Philadelphia|   PA|2017-03-15 13:25:17|            1|       4.0|             0|              0|\n|Philadelphia|   PA|2013-07-13 16:59:07|            1|       1.0|             1|              0|\n|Philadelphia|   PA|2014-11-30 16:41:38|            1|       5.0|             0|              1|\n|Philadelphia|   PA|2011-09-27 23:53:50|            1|       3.0|             0|              0|\n+------------+-----+-------------------+-------------+----------+--------------+---------------+\n\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=167"},{"jobUrl":"http://node-master:4040/jobs/job?id=168"},{"jobUrl":"http://node-master:4040/jobs/job?id=169"},{"jobUrl":"http://node-master:4040/jobs/job?id=170"},{"jobUrl":"http://node-master:4040/jobs/job?id=171"},{"jobUrl":"http://node-master:4040/jobs/job?id=172"},{"jobUrl":"http://node-master:4040/jobs/job?id=173"},{"jobUrl":"http://node-master:4040/jobs/job?id=174"},{"jobUrl":"http://node-master:4040/jobs/job?id=175"},{"jobUrl":"http://node-master:4040/jobs/job?id=176"},{"jobUrl":"http://node-master:4040/jobs/job?id=177"},{"jobUrl":"http://node-master:4040/jobs/job?id=178"},{"jobUrl":"http://node-master:4040/jobs/job?id=179"},{"jobUrl":"http://node-master:4040/jobs/job?id=180"},{"jobUrl":"http