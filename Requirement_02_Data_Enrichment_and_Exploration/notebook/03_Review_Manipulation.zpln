ay(Berlin, Riverside, Haddon Township, Audubon, Pennsauken, Chadds Ford, Sicklerville, Medford, Mt. Laurel, Williamstown, Maple Shade, Glen Mills, Burlington, Newtown Square, Nashville, Franklinville, Haddon Heights, Evesham, Cherry Hill, Kenner, Dunedin, Bryn Mawr, Tinicum Township, Jefferson, Marlton, Philadelphia, Hockessin, Mount Laurel, Moorestown, Camden, Conshohocken, Merchantville, Delran, Lawnside, Woodbury, Kennett Square, Collingswood, Blackwood, Bensalem, Havertown, Haddon township, New Hope, King of Prussia, Cinnaminson, Cherry Hill Mall, Tampa, Florence, Wyndmoor, Clearwater, Willow Grove, Metairie, Westmont, Voorhees, Ardmore, New Orleans, Haddonfield)\noxJJ0N82GFZeBCxBi6vH1A\t184\t0.012\tWrappedArray(West Chester, Schwenksville, Audubon, St. Davids, Berwyn, Haverford, Frontenac, Folcroft, Broomall, Ridley Park, Folsom, Springfield, Chester, Wayne, St. Louis, Manayunk, King Of Prussia, Bryn Mawr, Wilmington, Webster Groves, Narberth, Philadelphia, Upper Darby, Prospect Park, Malvern, Conshohocken, Norristown, Saint Louis, Bala Cynwyd, Holmes, Phoenixville, Rosemont, Elkins Park, Kennett Square, Radnor, Kirkwood, Havertown, Wynnewood, Norwood, Downingtown, King of Prussia, Lahaska, Plymouth Meeting, Ardmore, East Falls, Aldan)\nJSzIwMqdSI74_ztnbWzsEA\t183\t0.036\tWrappedArray(Indian Rocks Beach, Trinity, Riverview, Safety Harbor, Redington Shores, Saint Petersburg, Southwest Tampa, New Port Richey, Land O Lakes, NEW PORT RICHEY, Brandon, TAMPA, St. Louis, Madeira Beach, Dunedin, St. Petersburg, Temple Terrace, Saint Louis, Citrus Park, North Redington Bch, Palm Harbor, North Redington Beach, Clearwater Beach, Tarpon Springs, Largo, Westchase, St Petersburg, Pinellas Park, Metairie, Tampa, Odessa, New Orleans, Clearwater, Lutz, Hudson, Oldsmar)\nouODopBKF3AqfCkuQEnrDg\t182\t0.018\tWrappedArray(Paoli, Audubon, Colmar, Berwyn, North Wales, Ambler, Lafayette Hill, Haverford, Saint Davids, Glen Mills, Newtown Square, Devon, Wayne, Manayunk, King Of Prussia, Bryn Mawr, Horsham, East Norriton, Philadelphia, Upper Darby, Harleysville, Norristown, Conshohocken, Feasterville-Trevose, Lansdale, Levittown, Huntingdon Valley, Phoenixville, Radnor, Rosemont, NORRISTOWN, Gulph Mills, Blue Bell, Villanova, Fairless Hills, Wynnewood, Bensalem, New Hope, King of Prussia, Pottstown, Bristol, Southampton, Willow Grove, Plymouth Meeting, Spring House, Ardmore, Warrington)\nNGGd_11d2RXR8wTurenLgg\t180\t0.01\tWrappedArray(Bethel Township, Paoli, West Chester, Exton, Chadds Ford, Trooper, Berwyn, Newark, Haverford, Woodlyn, Boothwyn, Garnet Valley, Glen Mills, Broomall, Folsom, Springfield, Wayne, Upper Chichester, Bryn Mawr, Wilmington, Brookhaven, Aston, Philadelphia, Malvern, Lima, Norristown, Conshohocken, Lenni, Bala Cynwyd, Radnor, Rosemont, Kennett Square, Villanova, Havertown, Talleyville, Claymont, King of Prussia, Morton, Media, Plymouth Meeting, Ardmore, Wallingford)\n"},{"type":"TEXT","data":"\n\nUsers who are BOTH teleporters AND high-score ghost accounts: 0\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774593022456_613848624","id":"paragraph_1774416333730_1117657415","dateCreated":"2026-03-27T14:30:22+0800","status":"READY"},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\nbusiness_df = spark.table(\"business\")\n\nprint(\"Step 3b: Building co-review network to detect syndicates...\")\n\nghost_user_biz = (\n    ghost_accounts\n    .filter(F.col(\"ghost_score\") >= 3)\n    .select(\"user_id\", \"business_id\")\n    .distinct()\n)\n\nuser_pairs = (\n    ghost_user_biz.alias(\"a\")\n    .join(\n        ghost_user_biz.alias(\"b\"),\n        (F.col(\"a.business_id\") == F.col(\"b.business_id\")) &\n        (F.col(\"a.user_id\")    <  F.col(\"b.user_id\"))\n    )\n    .select(\n        F.col(\"a.user_id\").alias(\"user_1\"),\n        F.col(\"b.user_id\").alias(\"user_2\"),\n        F.col(\"a.business_id\").alias(\"shared_business\")\n    )\n)\n\n# --- Lowered threshold from 3 to 1 ---\nco_review_network = (\n    user_pairs\n    .groupBy(\"user_1\", \"user_2\")\n    .agg(F.count(\"shared_business\").alias(\"shared_biz_count\"))\n    .filter(F.col(\"shared_biz_count\") >= 1)\n    .orderBy(\"shared_biz_count\", ascending=False)\n)\n\nprint(f\"\\nSyndicate user-pair connections found: {co_review_network.count()}\")\nprint(\"\\n=== Strongest Syndicate Pairs (Most Shared Businesses) ===\")\nco_review_network.show(30, truncate=False)\nz.show(co_review_network.limit(30))\n\n# --- Node centrality ---\nuser_centrality = (\n    co_review_network\n    .select(F.col(\"user_1\").alias(\"user_id\"), \"shared_biz_count\")\n    .union(\n        co_review_network.select(F.col(\"user_2\").alias(\"user_id\"), \"shared_biz_count\")\n    )\n    .groupBy(\"user_id\")\n    .agg(\n        F.count(\"*\").alias(\"syndicate_connections\"),\n        F.sum(\"shared_biz_count\").alias(\"total_co_reviews\")\n    )\n    .orderBy(\"syndicate_connections\", ascending=False)\n)\n\nprint(\"\\n=== Most Connected Ghost Users (Network Hub Accounts) ===\")\nuser_centrality.show(20, truncate=False)\nz.show(user_centrality.limit(20))\n\n# --- Businesses most targeted ---\nghost_targeting = (\n    ghost_user_biz\n    .groupBy(\"business_id\")\n    .agg(F.count(\"user_id\").alias(\"ghost_account_count\"))\n    .join(business_df.select(\"business_id\", \"name\", \"city\", \"state\"), \"business_id\")\n    .select(\"name\", \"city\", \"state\", \"ghost_account_count\")\n    .orderBy(\"ghost_account_count\", ascending=False)\n)\n\nprint(\"\\n=== Businesses Most Targeted by Ghost Accounts ===\")\nghost_targeting.show(20, truncate=False)\nz.show(ghost_targeting.limit(20))","user":"anonymous","dateUpdated":"2026-03-27T16:59:30+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"user_1","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"user_2","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Step 3b: Building co-review network to detect syndicates...\n\nSyndicate user-pair connections found: 362924\n\n=== Strongest Syndicate Pairs (Most Shared Businesses) ===\n+----------------------+----------------------+----------------+\n|user_1                |user_2                |shared_biz_count|\n+----------------------+----------------------+----------------+\n|Tdsrg5IfAR4OhxQCO9qFfQ|gOmL86XU9QQ26F4TkPaFyw|2               |\n|MXB6G0ghmjQnLGNCJzgpxQ|WPvir9su9Jvf5nnKpWfC8g|2               |\n|PuHt70ZBMuT69lotWFxJzg|gOmL86XU9QQ26F4TkPaFyw|2               |\n|1WUqB7jcbu5uwTUJVSL2zQ|iHXi8xUGDlF7j4VdMe_PZg|2               |\n|PuHt70ZBMuT69lotWFxJzg|cNnfIpt5CeO-87lMk_e4RQ|2               |\n|Ijd0pUyM3Hw0lEfpsumW3A|PuHt70ZBMuT69lotWFxJzg|2               |\n|PuHt70ZBMuT69lotWFxJzg|Tdsrg5IfAR4OhxQCO9qFfQ|2               |\n|cNnfIpt5CeO-87lMk_e4RQ|gOmL86XU9QQ26F4TkPaFyw|2               |\n|Ijd0pUyM3Hw0lEfpsumW3A|gOmL86XU9QQ26F4TkPaFyw|2               |\n|SEkbUpwpPHdSnBN3mcGn4g|qu7rVt2iPsQ_Ccf09CEeYg|2               |\n|Ijd0pUyM3Hw0lEfpsumW3A|cNnfIpt5CeO-87lMk_e4RQ|2               |\n|Tdsrg5IfAR4OhxQCO9qFfQ|cNnfIpt5CeO-87lMk_e4RQ|2               |\n|Ijd0pUyM3Hw0lEfpsumW3A|Tdsrg5IfAR4OhxQCO9qFfQ|2               |\n|-1BTgZVpUVdcBaF8X-xeyg|Uaxor1pdX2OoyA8w91rj4w|1               |\n|3F-m6ESk6MOkzGOh4iR5uA|Fk-x-tFaBlYCa6V25__sTQ|1               |\n|-1BTgZVpUVdcBaF8X-xeyg|LYNF5oLS3Ns4_TyOXYBzOQ|1               |\n|218xz1NQOJSpvMqq4BdkGQ|DHM