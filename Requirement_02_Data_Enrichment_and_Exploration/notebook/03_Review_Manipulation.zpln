== Overall Consequence Summary ===\n+----------------------------+-----------------+-----------------------+----------------+-------------+-------------------+--------------+----------+----------------+\n|total_manipulated_businesses|avg_rating_before|avg_rating_during_spike|avg_rating_after|avg_fake_lift|avg_post_spike_drop|avg_net_change|now_closed|closure_rate_pct|\n+----------------------------+-----------------+-----------------------+----------------+-------------+-------------------+--------------+----------+----------------+\n|214                         |4.38             |4.59                   |4.16            |0.21         |0.42               |-0.21         |15        |7.01            |\n+----------------------------+-----------------+-----------------------+----------------+-------------+-------------------+--------------+----------+----------------+\n\n"},{"type":"TABLE","data":"total_manipulated_businesses\tavg_rating_before\tavg_rating_during_spike\tavg_rating_after\tavg_fake_lift\tavg_post_spike_drop\tavg_net_change\tnow_closed\tclosure_rate_pct\n214\t4.38\t4.59\t4.16\t0.21\t0.42\t-0.21\t15\t7.01\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774593022461_261924329","id":"paragraph_1774419150002_329329593","dateCreated":"2026-03-27T14:30:22+0800","status":"READY"},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\nprint(\"Step 4b: Closure rate breakdown by manipulation intensity...\")\n\n# --- Segment businesses by post-spike rating drop magnitude ---\nclosure_by_manipulation = (\n    consequence_analysis\n    .withColumn(\"manipulation_tier\",\n        F.when(F.col(\"rating_drop_after_spike\") >= 1.5, \"Severe  (drop >= 1.5 stars)\")\n         .when(F.col(\"rating_drop_after_spike\") >= 1.0, \"Heavy   (drop >= 1.0 stars)\")\n         .when(F.col(\"rating_drop_after_spike\") >= 0.5, \"Moderate(drop >= 0.5 stars)\")\n         .otherwise(                                     \"Light   (drop < 0.5 stars)\")\n    )\n    .groupBy(\"manipulation_tier\")\n    .agg(\n        F.count(\"*\").alias(\"business_count\"),\n        F.round(\n            F.sum(F.when(F.col(\"still_open\") == 0, 1).otherwise(0)) /\n            F.count(\"*\") * 100, 1\n        ).alias(\"closure_rate_pct\"),\n        F.round(F.avg(\"avg_before\"),              2).alias(\"avg_pre_spike_rating\"),\n        F.round(F.avg(\"avg_during\"),              2).alias(\"avg_peak_rating\"),\n        F.round(F.avg(\"avg_after\"),               2).alias(\"avg_post_spike_rating\"),\n        F.round(F.avg(\"rating_drop_after_spike\"), 2).alias(\"avg_drop\"),\n        F.round(F.avg(\"net_long_term_change\"),    2).alias(\"avg_net_change\")\n    )\n    .orderBy(\"closure_rate_pct\", ascending=False)\n)\n\nprint(\"\\n=== Closure Rate by Manipulation Intensity ===\")\nclosure_by_manipulation.show(truncate=False)\nz.show(closure_by_manipulation)\n\n# --- Review volume change: did fake boost attract real reviewers? ---\nprint(\"\\n=== Review Volume Change After Spike ===\")\nvolume_analysis = (\n    consequence_analysis\n    .withColumn(\"volume_change_pct\",\n        F.round(\n            (F.col(\"review_count_after\") - F.col(\"review_count_before\")) /\n            (F.col(\"review_count_before\") + 1) * 100, 1\n        )\n    )\n    .groupBy(\n        F.when(F.col(\"still_open\") == 1, \"Open\").otherwise(\"Closed\").alias(\"status\")\n    )\n    .agg(\n        F.count(\"*\").alias(\"count\"),\n        F.round(F.avg(\"volume_change_pct\"),    2).alias(\"avg_volume_change_pct\"),\n        F.round(F.avg(\"review_count_before\"),  1).alias(\"avg_reviews_before\"),\n        F.round(F.avg(\"review_count_after\"),   1).alias(\"avg_reviews_after\"),\n        F.round(F.avg(\"net_long_term_change\"), 2).alias(\"avg_net_rating_change\")\n    )\n)\nvolume_analysis.show(truncate=False)\nz.show(volume_analysis)","user":"anonymous","dateUpdated":"2026-03-27T17:14:51+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"manipulation_tier","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"business_count","index":1,"aggr":"sum"}]}},"3":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"status","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"count","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Step 4b: Closure rate breakdown by manipulation intensity...\n\n=== Closure Rate by Manipulation Intensity ===\n+---------------------------+--------------+----------------+--------------------+---------------+---------------------+--------+--------------+\n|manipulation_tier          |business_count|closure_rate_pct|avg_pre_spike_rating|avg_peak_rating|avg_post_spike_rating|avg_drop|avg_net_change|\n+---------------------------+--------------+----------------+--------------------+---------------+---------------------+--------+--------------+\n|Heavy   (drop >= 1.0 stars)|18            |16.7            |4.14                |4.69           |3.48                 |1.21    |-0.66         |\n|Light   (drop < 0.5 stars) |150           |6.7             |4.46                |4.58           |4.44                 |0.13    |-0.02         |\n|Moderate(drop >= 0.5 stars)|36            |5.6             |4.26                |4.57           |3.87                 |0.7     |-0.38         |\n|Severe  (drop >= 1.5 stars)|10            |0.0             |4.0                 |4.64           |2.4                  |2.24    |-1.6          |\n+---------------------------+--------------+----------------+--------------------+---------------+---------------------+--------+--------------+\n\n"},{"type":"TABLE","data":"manipulation_tier\tbusiness_count\tclosure_rate_pct\tavg_pre_spike_rating\tavg_peak_rating\tavg_post_spike_rating\tavg_drop\tavg_net_change\nHeavy   (drop >= 1.0 stars)\t18\t16.7\t4.14\t4.69\t3.48\t1.21\t-0.66\nLight   (drop < 0.5 stars)\t150\t6.7\t4.46\t4.58\t4.44\t0.13\t-0.02\nModerate(drop >= 0.5 stars)\t36\t5.6\t4.26\t4.57\t3.87\t0.7\t-0.38\nSevere  (drop >= 1.5 stars)\t10\t0.0\t4.0\t4.64\t2.4\t2.24\t-1.6\n"},{"type":"TEXT","data":"\n\n=== Review Volume Change After Spike ===\n+------+-----+---------------------+------------------+-----------------+---------------------+\n|status|count|avg_volume_change_pct|avg_reviews_before|avg_reviews_after|avg_net_rating_change|\n+------+-----+---------------------+------------------+-----------------+---------------------+\n|Open  |199  |349.84               |19.6              |37.7             |-0.22                |\n|Closed|15   |415.93               |18.3              |39.7             |-0.12                |\n+------+-----+---------------------+------------------+-----------------+---------------------+\n\n"},{"type":"TABLE","data":"status\tcount\tavg_volume_change_pct\tavg_reviews_before\tavg_reviews_after\tavg_net_rating_change\nOpen\t199\t349.84\t19.6\t37.7\t-0.22\nClosed\t15\t415.93\t18.3\t39.7\t-0.12\n"}]},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774593022474_1935980487","id":"paragraph_1774419574220_2107206522","dateCreated":"2026-03-27T14:30:22+0800","status":"READY"},{"text":"%pyspark\n","user":"anonymous","dateUpdated":"2026-03-27T14:30:22+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"apps":[],"runtimeInfos":{},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774593022479_1582091196","id":"paragraph_1774419744868_1431632815","dateCreated":"2026-03-27T14:30:22+0800","status":"READY"}],"name":"Review_Manipulation","id":"2MN52MTSN","defaultInterpreterGroup":"spark","version":"0.12.0","noteParams":{},"noteForms":{},"angularObjects":{},"config":{"isZeppelinNotebookCronEnable":false,"looknfeel":"default","personalizedMode":"false"},"info":{},"path":"/Review_Manipulation"}