cken\tPA\t1\t103\t3.47\t10194\nEdgemont\tPA\t1\t1\t2.0\t20\nWillow Grove\tPA\t1\t184\t2.93\t14872\nPlant City\tFL\t1\t111\t3.36\t4504\nWarminster\tPA\t1\t93\t3.47\t3774\nMadison\tTN\t1\t95\t2.53\t3549\nFenton\tMO\t1\t89\t3.11\t3132\nHammonton\tNJ\t1\t10\t3.95\t296\nRoslyn\tPA\t1\t8\t3.31\t155\nCamby\tIN\t1\t19\t2.84\t445\nGoodletsville\tTN\t1\t1\t4.0\t192\nHarvey\tLA\t1\t117\t3.24\t5088\nDelran\tNJ\t1\t39\t3.86\t1242\n"},{"type":"TEXT","data":"\n\n=== Cities Bucketed by Starbucks Count ===\n+------------------------+----------+----------+---------------+-----------+-------------+\n|starbucks_tier          |city_count|avg_rating|avg_restaurants|avg_reviews|avg_starbucks|\n+------------------------+----------+----------+---------------+-----------+-------------+\n|High (40+ Starbucks)    |4         |3.343     |4255.0         |420675.0   |50.8         |\n|Medium (20-39 Starbucks)|3         |3.12      |2383.0         |297600.0   |24.3         |\n|Low (10-19 Starbucks)   |4         |3.683     |1080.0         |158938.0   |12.8         |\n|Minimal (< 10 Starbucks)|196       |3.424     |106.0          |8590.0     |2.1          |\n+------------------------+----------+----------+---------------+-----------+-------------+\n\nNone\n"},{"type":"TABLE","data":"starbucks_tier\tcity_count\tavg_rating\tavg_restaurants\tavg_reviews\tavg_starbucks\nHigh (40+ Starbucks)\t4\t3.343\t4255.0\t420675.0\t50.8\nMedium (20-39 Starbucks)\t3\t3.12\t2383.0\t297600.0\t24.3\nLow (10-19 Starbucks)\t4\t3.683\t1080.0\t158938.0\t12.8\nMinimal (< 10 Starbucks)\t196\t3.424\t106.0\t8590.0\t2.1\n"},{"type":"TEXT","data":"\n\n=== Correlation: Starbucks Count vs Avg Restaurant Rating ===\nPearson Correlation Coefficient: -0.0133\nPearson Correlation (Starbucks vs Total Reviews): 0.7722\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=26"},{"jobUrl":"http://node-master:4040/jobs/job?id=27"},{"jobUrl":"http://node-master:4040/jobs/job?id=28"},{"jobUrl":"http://node-master:4040/jobs/job?id=29"},{"jobUrl":"http://node-master:4040/jobs/job?id=30"},{"jobUrl":"http://node-master:4040/jobs/job?id=31"},{"jobUrl":"http://node-master:4040/jobs/job?id=32"},{"jobUrl":"http://node-master:4040/jobs/job?id=33"},{"jobUrl":"http://node-master:4040/jobs/job?id=34"},{"jobUrl":"http://node-master:4040/jobs/job?id=35"},{"jobUrl":"http://node-master:4040/jobs/job?id=36"},{"jobUrl":"http://node-master:4040/jobs/job?id=37"},{"jobUrl":"http://node-master:4040/jobs/job?id=38"},{"jobUrl":"http://node-master:4040/jobs/job?id=39"},{"jobUrl":"http://node-master:4040/jobs/job?id=40"},{"jobUrl":"http://node-master:4040/jobs/job?id=41"},{"jobUrl":"http://node-master:4040/jobs/job?id=42"},{"jobUrl":"http://node-master:4040/jobs/job?id=43"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774633399557_1400987094","id":"paragraph_1774633399557_1400987094","dateCreated":"2026-03-28T01:43:20+0800","dateStarted":"2026-03-28T01:48:55+0800","dateFinished":"2026-03-28T01:51:00+0800","status":"FINISHED","focus":false},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\nprint(\"Step 4: Deep dive analysis...\")\n\n# Review activity per restaurant by starbucks tier\nprint(\"\\n=== Reviews Per Restaurant by Starbucks Tier ===\")\ntier_deep = (\n    city_consolidated\n    .withColumn(\"starbucks_tier\",\n        F.when(F.col(\"starbucks_count\") >= 40, \"1_High (40+ Starbucks)\")\n         .when(F.col(\"starbucks_count\") >= 20, \"2_Medium (20-39 Starbucks)\")\n         .when(F.col(\"starbucks_count\") >= 10, \"3_Low (10-19 Starbucks)\")\n         .otherwise(\"4_Minimal (< 10 Starbucks)\")\n    )\n    .withColumn(\"reviews_per_restaurant\",\n        F.round(F.col(\"total_reviews\") / F.col(\"total_restaurants\"), 1)\n    )\n    .groupBy(\"starbucks_tier\")\n    .agg(\n        F.count(\"*\").alias(\"city_count\"),\n        F.round(F.avg(\"avg_restaurant_rating\"), 3).alias(\"avg_rating\"),\n        F.round(F.avg(\"total_restaurants\"), 0).alias(\"avg_restaurants\"),\n        F.round(F.avg(\"total_reviews\"), 0).alias(\"avg_reviews\"),\n        F.round(F.avg(\"reviews_per_restaurant\"), 1).alias(\"avg_reviews_per_restaurant\"),\n        F.round(F.avg(\"starbucks_count\"), 1).alias(\"avg_starbucks\")\n    )\n    .orderBy(\"starbucks_tier\")\n)\ntier_deep.show(truncate=False)\nz.show(tier_deep)\n\n# Top vs Bottom cities comparison\nprint(\"\\n=== Top 5 HIGH Starbucks Cities ===\")\ntop5 = (\n    city_consolidated\n    .orderBy(\"starbucks_count\", ascending=False)\n    .limit(5)\n    .withColumn(\"reviews_per_restaurant\",\n        F.round(F.col(\"total_reviews\") / F.col(\"total_restaurants\"), 1))\n)\ntop5.show(truncate=False)\n\nprint(\"\\n=== Top 5 LOW Starbucks Cities ===\")\nbottom5 = (\n    city_consolidated\n    .orderBy(\"starbucks_count\", ascending=True)\n    .limit(5)\n    .withColumn(\"reviews_per_restaurant\",\n        F.round(F.col(\"total_reviews\") / F.col(\"total_restaurants\"), 1))\n)\nbottom5.show(truncate=False)\n\n# Correlation numbers\nprint(\"\\n=== CORRELATION RESULTS ===\")\ncorr1 = city_consolidated.stat.corr(\"starbucks_count\", \"avg_restaurant_rating\")\ncorr2 = city_consolidated.stat.corr(\"starbucks_count\", \"total_reviews\")\ncorr3 = city_consolidated.stat.corr(\"starbucks_count\", \"total_restaurants\")\n\nprint(f\"Starbucks Count vs Avg Restaurant Rating : {corr1:.4f}\")\nprint(f\"Starbucks Count vs Total Reviews         : {corr2:.4f}\")\nprint(f\"Starbucks Count vs Total Restaurants     : {corr3:.4f}\")\n\nprint(\"\\n✅ Step 4 Done!\")","user":"anonymous","dateUpdated":"2026-03-28T14:03:10+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"starbucks_tier","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"city_count","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Step 4: Deep dive analysis...\n\n=== Reviews Per Restaurant by Starbucks Tier ===\n+--------------------------+----------+----------+---------------+-----------+--------------------------+-------------+\n|starbucks_tier            |city_count|avg_rating|avg_restaurants|avg_reviews|avg_reviews_per_restaurant|avg_starbucks|\n+--------------------------+----------+----------+---------------+-----------+--------------------------+-------------+\n|1_High (40+ Starbucks)    |4         |3.343     |4255.0         |420675.0   |98.5                      |50.8         |\n|2_Medium (20-39 Starbucks)|3         |3.12      |2383.0         |297600.0   |117.1                     |24.3         |\n|3_Low (10-19 Starbucks)   |4         |3.683     |1080.0         |158938.0   |114.7                     |12.8         |\n|4_Minimal (< 10 Starbucks)|196       |3.424     |106.0          |8590.0     |61.2                      |2.1          |\n+--------------------------+----------+----------+---------------+-----------+--------------------------+-------------+\n\n"},{"type":"TABLE","data":"starbucks_tier\tcity_count\tavg_rating\tavg_restaurants\tavg_reviews\tavg_reviews_per_restaurant\tavg_starbucks\n1_High (40+ Starbucks)\t4\t3.343\t4255.0\t420675.0\t98.5\t50.8\n2_Medium (20-39 Starbucks)\t3\t3.12\t2383.0\t297600.0\t117.1\t24.3\n3_Low (10-19 Starbucks)\t4\t3.682\t1080.0\t158938.0\t114.7\t12.8\n4_Minimal (< 10 Starbucks)\t196\t3.424\t106.0\t8590.0\t61.2\t2.1\n"},{"type":"TEXT","data":"\n\n=== Top 5 HIGH Starbucks Cities ===\n+------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n|city_clean  |state|starbucks_count|total_restaurants|avg_restaurant_rating|total_reviews|reviews_per_restaurant|\n+------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n|Tucson      |AZ   |59             |2473             |2.9                  |239116       |96.7                  |\n|Indianapolis|IN   |55             |5724             |3.49                 |484048       |84.6                  |\n|Philadelphia|PA   |47             |5856             |3.78                 |665958       |113.7                 |\n|Tampa       |FL   |42             |2968             |3.2                  |293577       |98.9                  |\n|Reno        |NV   |27             |1290             |3.53                 |191232       |148.2                 |\n+------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n\n\n=== Top 5 LOW Starbucks Cities ===\n+-------------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n|city_clean         |state|starbucks_count|total_restaurants|avg_restaurant_rating|total_reviews|reviews_per_restaurant|\n+-------------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n|Feasterville       |PA   |1              |20               |3.25                 |1227         |61.4                  |\n|Ferguson           |MO   |1              |24               |3.38                 |915          |38.1                  |\n|Gloucester Township|NJ   |1              |8                |3.63                 |484          |60.5                  |\n|East Norriton      |PA   |1              |34               |3.41                 |2581         |75.9                  |\n|Newtown Square     |PA   |1              |59               |3.46                 |3742         |63.4                  |\n+-------------------+-----+---------------+-----------------+---------------------+-------------+----------------------+\n\n\n=== CORRELATION RESULTS ===\nStarbucks Count vs Avg Restaurant Rating : -0.0133\nStarbucks Count vs Total Reviews         : 0.7722\nStarbucks Count vs Total Restaurants     : 0.8495\n\n✅ Step 4 Done!\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=44"},{"jobUrl":"http://node-master:4040/jobs/job?id=45"},{"jobUrl":"http://node-master:4040/jobs/job?id=46"},{"jobUrl":"http://node-master:4040/jobs/job?id=47"},{"jobUrl":"http://node-master:4040/jobs/job?id=48"},{"jobUrl":"http://node-master:4040/jobs/job?id=49"},{"jobUrl":"http://node-master:4040/jobs/job?id=50"},{"jobUrl":"http://node-master:4040/jobs/job?id=51"},{"jobUrl":"http://node-master:4040/jobs/job?id=52"},{"jobUrl":"http://node-master:4040/jobs/job?id=53"},{"jobUrl":"http://node-master:4040/jobs/job?id=54"},{"jobUrl":"http://node-master:4040/jobs/job?id=55"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774633735266_578147639","id":"paragraph_1774633735266_578147639","dateCreated":"2026-03-28T01:48:55+0800","dateStarted":"2026-03-28T01:54:06+0800","dateFinished":"2026-03-28T01:55:16+0800","status":"FINISHED","focus":false},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\nprint(\"Step 4: Deep insight analysis...\")\n\n# Top vs Bottom Starbucks cities comparison\nprint(\"\\n=== HIGH Starbucks Cities (40+) ===\")\nhigh_sbux = city_consolidated.filter(F.col(\"starbucks_count\") >= 40)\nhigh_sbux.show(truncate=False)\n\nprint(\"\\n=== LOW Starbucks Cities (< 10) ===\")\nlow_sbux = city_consolidated.filter(F.col(\"starbucks_count\") < 10)\nlow_sbux.show(truncate=False)\n\n# Reviews per restaurant ratio\nprint(\"\\n=== Review Engagement Rate by City ===\")\nengagement = (\n    city_consolidated\n    .withColumn(\"reviews_per_restaurant\",\n        F.round(F.col(\"total_reviews\") / F.col(\"total_restaurants\"), 1))\n    .withColumn(\"starbucks_tier\",\n        F.when(F.col(\"starbucks_count\") >= 40, \"High (40+)\")\n         .when(F.col(\"starbucks_count\") >= 20, \"Medium (20-39)\")\n         .when(F.col(\"starbucks_count\") >= 10, \"Low (10-19)\")\n         .otherwise(\"Minimal (<10)\")\n    )\n    .select(\n        \"city_clean\", \"state\",\n        \"starbucks_count\",\n        \"total_restaurants\",\n        \"avg_restaurant_rating\",\n        \"reviews_per_restaurant\",\n        \"starbucks_tier\"\n    )\n    .orderBy(\"starbucks_count\", ascending=False)\n)\n\nengagement.cache()\nengagement.show(20, truncate=False)\nz.show(engagement)\n\n# Summary stats by tier\nprint(\"\\n=== FINAL SUMMARY: Starbucks Tier vs Restaurant Metrics ===\")\nfinal_summary = (\n    engagement\n    .groupBy(\"starbucks_tier\")\n    .agg(\n        F.count(\"*\").alias(\"num_cities\"),\n        F.round(F.avg(\"starbucks_count\"), 1).alias(\"avg_starbucks\"),\n        F.round(F.avg(\"avg_restaurant_rating\"), 3).alias(\"avg_rating\"),\n        F.round(F.avg(\"total_restaurants\"), 0).alias(\"avg_restaurants\"),\n        F.round(F.avg(\"reviews_per_restaurant\"), 1).alias(\"avg_reviews_per_restaurant\")\n    )\n    .orderBy(\"avg_starbucks\", ascending=False)\n)\n\nfinal_summary.show(truncate=False)\nz.show(final_summary)\n\n# Print correlation summary\nprint(\"\\n\" + \"=\"*50)\nprint(\"HYPOTHESIS VALIDATION SUMMARY\")\nprint(\"=\"*50)\ncorr1 = city_consolidated.stat.corr(\"starbucks_count\", \"avg_restaurant_rating\")\ncorr2 = city_consolidated.stat.corr(\"starbucks_count\", \"total_reviews\")\ncorr3 = city_consolidated.stat.corr(\"starbucks_count\", \"total_restaurants\")\n\nprint(f\"Starbucks vs Avg Rating correlation:      {corr1:.4f}\")\nprint(f\"Starbucks vs Total Reviews correlation:   {corr2:.4f}\")\nprint(f\"Starbucks vs Total Restaurants correlation: {corr3:.4f}\")\n\nif corr1 > 0.3:\n    print(\"\\n✅ HYPOTHESIS SUPPORTED: More Starbucks = Higher ratings\")\nelif corr1 < -0.3:\n    print(\"\\n❌ HYPOTHESIS REJECTED: More Starbucks = Lower ratings\")\nelse:\n    print(\"\\n⚠️ HYPOTHESIS PARTIALLY SUPPORTED: Weak correlation found\")\nprint(\"=\"*50)","user":"anonymous","dateUpdated":"2026-03-28T14:09:04+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"city_clean","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"state","index":1,"aggr":"sum"}]}},"3":{"graph":{"mode":"multiBarChart","height":300,"optionOpen":false,"setting":{"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{},"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false}},"keys":[{"name":"starbucks_tier","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"num_cities","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Step 4: Deep insight analysis...\n\n=== HIGH Starbucks Cities (40+) ===\n+------------+-----+---------------+-----------------+---------------------+-------------+\n|city_clean  |state|starbucks_count|total_restaurants|avg_restaurant_rating|total_reviews|\n+------------+-----+---------------+-----------------+------------