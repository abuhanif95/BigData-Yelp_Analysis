{"paragraphs":[{"text":"%pyspark\r\nfrom pyspark.sql import functions as F\r\n\r\nprint(\"Loading all data...\")\r\n\r\n# Load Yelp data\r\nreview_df = spark.read.json(\"/user/shirsha/yelp/review\")\r\nbusiness_df = spark.read.json(\"/user/shirsha/yelp/business\")\r\n\r\nreview_df.cache()\r\nbusiness_df.cache()\r\n\r\n# Load Starbucks external data\r\nstarbucks_df = spark.read.csv(\r\n    \"/user/shirsha/external/starbucks.csv\",\r\n    header=True,\r\n    inferSchema=True\r\n)\r\nstarbucks_df.cache()\r\n\r\n# Register views\r\nreview_df.createOrReplaceTempView(\"review\")\r\nbusiness_df.createOrReplaceTempView(\"business\")\r\nstarbucks_df.createOrReplaceTempView(\"starbucks\")\r\n\r\nprint(f\"✅ Reviews: {review_df.count():,}\")\r\nprint(f\"✅ Businesses: {business_df.count():,}\")\r\nprint(f\"✅ Starbucks locations: {starbucks_df.count():,}\")\r\n\r\nprint(\"\\nStarbucks schema:\")\r\nstarbucks_df.printSchema()\r\nprint(\"\\nStarbucks sample:\")\r\nstarbucks_df.show(3, truncate=False)","user":"anonymous","dateUpdated":"2026-03-28T00:54:20+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Loading all data...\n✅ Reviews: 6,990,280\n✅ Businesses: 150,346\n✅ Starbucks locations: 25,601\n\nStarbucks schema:\nroot\n |-- Brand: string (nullable = true)\n |-- Store Number: string (nullable = true)\n |-- Store Name: string (nullable = true)\n |-- Ownership Type: string (nullable = true)\n |-- Street Address: string (nullable = true)\n |-- City: string (nullable = true)\n |-- State/Province: string (nullable = true)\n |-- Country: string (nullable = true)\n |-- Postcode: string (nullable = true)\n |-- Phone Number: string (nullable = true)\n |-- Timezone: string (nullable = true)\n |-- Longitude: string (nullable = true)\n |-- Latitude: double (nullable = true)\n\n\nStarbucks sample:\n+---------+------------+----------------+--------------+----------------------------+----------------+--------------+-------+--------+------------+-----------------------+---------+--------+\n|Brand    |Store Number|Store Name      |Ownership Type|Street Address              |City            |State/Province|Country|Postcode|Phone Number|Timezone               |Longitude|Latitude|\n+---------+------------+----------------+--------------+----------------------------+----------------+--------------+-------+--------+------------+-----------------------+---------+--------+\n|Starbucks|47370-257954|Meritxell, 96   |Licensed      |Av. Meritxell, 96           |Andorra la Vella|7             |AD     |AD500   |376818720   |GMT+1:00 Europe/Andorra|1.53     |42.51   |\n|Starbucks|22331-212325|Ajman Drive Thru|Licensed      |1 Street 69, Al Jarf        |Ajman           |AJ            |AE     |NULL    |NULL        |GMT+04:00 Asia/Dubai   |55.47    |25.42   |\n|Starbucks|47089-256771|Dana Mall       |Licensed      |Sheikh Khalifa Bin Zayed St.|Ajman           |AJ            |AE     |NULL    |NULL        |GMT+04:00 Asia/Dubai   |55.47    |25.39   |\n+---------+------------+----------------+--------------+----------------------------+----------------+--------------+-------+--------+------------+-----------------------+---------+--------+\nonly showing top 3 rows\n\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=0"},{"jobUrl":"http://node-master:4040/jobs/job?id=1"},{"jobUrl":"http://node-master:4040/jobs/job?id=2"},{"jobUrl":"http://node-master:4040/jobs/job?id=3"},{"jobUrl":"http://node-master:4040/jobs/job?id=4"},{"jobUrl":"http://node-master:4040/jobs/job?id=5"},{"jobUrl":"http://node-master:4040/jobs/job?id=6"},{"jobUrl":"http://node-master:4040/jobs/job?id=7"},{"jobUrl":"http://node-master:4040/jobs/job?id=8"},{"jobUrl":"http://node-master:4040/jobs/job?id=9"},{"jobUrl":"http://node-master:4040/jobs/job?id=10"},{"jobUrl":"http://node-master:4040/jobs/job?id=11"},{"jobUrl":"http://node-master:4040/jobs/job?id=12"},{"jobUrl":"http://node-master:4040/jobs/job?id=13"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774630449296_1213885610","id":"paragraph_1774630449296_1213885610","dateCreated":"2026-03-28T00:54:09+0800","dateStarted":"2026-03-28T00:54:20+0800","dateFinished":"2026-03-28T01:41:52+0800","status":"FINISHED","focus":false},{"text":"%pyspark\nfrom pyspark.sql import functions as F\n\nprint(\"Step 2: Filtering US Starbucks and matching Yelp cities...\")\n\n# Filter US only Starbucks\nus_starbucks = (\n    starbucks_df\n    .filter(F.col(\"Country\") == \"US\")\n    .select(\n        F.col(\"City\").alias(\"sbux_city\"),\n        F.col(\"State/Province\").alias(\"sbux_state\"),\n        F.col(\"Longitude\").alias(\"sbux_lon\"),\n        F.col(\"Latitude\").alias(\"sbux_lat\")\n    )\n)\n\n# Count Starbucks per city\nsbux_per_city = (\n    us_starbucks\n    .groupBy(\"sbux_city\", \"sbux_state\")\n    .agg(F.count(\"*\").alias(\"starbucks_count\"))\n)\n\n# Get Yelp cities - restaurants only\nyelp_cities = (\n    business_df\n    .filter(F.col(\"categories\").like(\"%Restaurant%\"))\n    .groupBy(\"city\", \"state\")\n    .agg(\n        F.count(\"*\").alias(\"restaurant_count\"),\n        F.round(F.avg(\"stars\"), 2).alias(\"avg_rating\"),\n        F.sum(\"review_count\").alias(\"total_reviews\")\n    )\n)\n\n# Join Starbucks count with Yelp cities\ncity_analysis = (\n    yelp_cities\n    .join(\n        sbux_per_city,\n        (F.lower(F.col(\"city\")) == F.lower(F.col(\"sbux_city\"))) &\n        (F.col(\"state\") == F.col(\"sbux_state\"))\n    )\n    .select(\n        \"city\", \"state\",\n        \"starbucks_count\",\n        \"restaurant_count\",\n        \"avg_rating\",\n        \"total_reviews\"\n    )\n    .orderBy(\"starbucks_count\", ascending=False)\n)\n\ncity_analysis.cache()\n\nprint(f\"\\n✅ Cities matched: {city_analysis.count()}\")\nprint(\"\\n=== Starbucks Count vs Restaurant Ratings by City ===\")\ncity_analysis.show(20, truncate=False)\nz.show(city_analysis)","user":"anonymous","dateUpdated":"2026-03-28T13:43:09+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"1":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"city","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"state","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Step 2: Filtering US Starbucks and matching Yelp cities...\n\n✅ Cities matched: 259\n\n=== Starbucks Count vs Restaurant Ratings by City ===\n+------------+-----+---------------+----------------+----------+-------------+\n|city        |state|starbucks_count|restaurant_count|avg_rating|total_reviews|\n+------------+-----+---------------+----------------+----------+-------------+\n|Tucson      |AZ   |59             |2470            |3.46      |238902       |\n|tucson      |AZ   |59             |1               |3.5       |155          |\n|TUCSON      |AZ   |59             |2               |1.75      |59           |\n|Indianapolis|IN   |55             |2862            |3.49      |242024       |\n|philadelphia|PA   |47             |2               |4.0       |209          |\n|Philadelphia|PA   |47             |5854            |3.56      |665749       |\n|Tamp