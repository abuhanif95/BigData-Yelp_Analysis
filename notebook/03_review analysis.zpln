{"paragraphs":[{"text":"%pyspark\r\n\r\n# Load datasets if not already loaded (optional, run once)\r\nuser_df = spark.read.json(\"/user/shirsha/yelp/user\")\r\nuser_df.createOrReplaceTempView(\"yelp_user\")\r\nbusiness_df = spark.read.json(\"/user/shirsha/yelp/business\")\r\nbusiness_df.createOrReplaceTempView(\"yelp_business\")\r\nreview_df = spark.read.json(\"/user/shirsha/yelp/review\")\r\nreview_df.createOrReplaceTempView(\"yelp_review\")\r\ncheckin_df = spark.read.json(\"/user/shirsha/yelp/checkin\")\r\ncheckin_df.createOrReplaceTempView(\"yelp_checkin\")\r\ntip_df = spark.read.json(\"/user/shirsha/yelp/tip\")\r\ntip_df.createOrReplaceTempView(\"yelp_tip\")\r\n\r\nprint(\"All data loaded.\")","user":"anonymous","dateUpdated":"2026-03-25T20:36:14+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"All data loaded.\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=52"},{"jobUrl":"http://node-master:4040/jobs/job?id=53"},{"jobUrl":"http://node-master:4040/jobs/job?id=54"},{"jobUrl":"http://node-master:4040/jobs/job?id=55"},{"jobUrl":"http://node-master:4040/jobs/job?id=56"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774442163435_671818863","id":"paragraph_1774442163435_671818863","dateCreated":"2026-03-25T20:36:03+0800","dateStarted":"2026-03-25T20:36:14+0800","dateFinished":"2026-03-25T20:44:39+0800","status":"FINISHED","focus":false},{"text":"%pyspark\n\nfrom pyspark.sql.functions import year, to_date, col, count\n\nreviews_per_year = spark.table(\"yelp_review\") \\\n    .withColumn(\"year\", year(to_date(col(\"date\")))) \\\n    .groupBy(\"year\") \\\n    .agg(count(\"*\").alias(\"num_reviews\")) \\\n    .orderBy(\"year\")\n\nz.show(reviews_per_year)","user":"anonymous","dateUpdated":"2026-03-26T03:36:49+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"0":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"year","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"num_reviews","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"year\tnum_reviews\n2005\t854\n2006\t3853\n2007\t15363\n2008\t48226\n2009\t74387\n2010\t138587\n2011\t230813\n2012\t286570\n2013\t383950\n2014\t522275\n2015\t688415\n2016\t758882\n2017\t820048\n2018\t906362\n2019\t907284\n2020\t554557\n2021\t618189\n2022\t31665\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=5"},{"jobUrl":"http://node-master:4040/jobs/job?id=6"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774442174277_571555906","id":"paragraph_1774442174277_571555906","dateCreated":"2026-03-25T20:36:14+0800","dateStarted":"2026-03-25T23:44:33+0800","dateFinished":"2026-03-25T23:54:08+0800","status":"FINISHED"},{"text":"%pyspark\n\nfrom pyspark.sql.functions import sum, col\n\nreview_votes = spark.table(\"yelp_review\") \\\n    .agg(\n        sum(\"useful\").alias(\"total_useful\"),\n        sum(\"funny\").alias(\"total_funny\"),\n        sum(\"cool\").alias(\"total_cool\")\n    )\n\nz.show(review_votes)","user":"anonymous","dateUpdated":"2026-03-26T03:36:47+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"enabled":true,"results":{"0":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stream"},"scatterChart":{}},"keys":[{"name":"total_useful","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"total_funny","index":1,"aggr":"sum"}]}}},"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"total_useful\ttotal_funny\ttotal_cool\n8280748\t2282743\t3485476\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=7"},{"jobUrl":"http://node-master:4040/jobs/job?id=8"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774442796368_953458806","id":"paragraph_1774442796368_953458806","dateCreated":"2026-03-25T20:46:36+0800","dateStarted":"2026-03-25T23:56:00+0800","dateFinished":"2026-03-26T00:01:53+0800","status":"FINISHED"},{"text":"%pyspark\n\n# Load review data from your HDFS path\nreview_df = spark.read.json(\"/user/shirsha/yelp/review\")\nreview_df.createOrReplaceTempView(\"yelp_review\")\nprint(\"Review data loaded. Total records: \" + str(review_df.count()))\n\n# Also load business data if not already loaded (needed for some later tasks)\nbusiness_df = spark.read.json(\"/user/shirsha/yelp/business\")\nbusiness_df.createOrReplaceTempView(\"yelp_business\")\nprint(\"Business data loaded.\")\n\n# Load user data if needed (for user-related analysis)\nuser_df = spark.read.json(\"/user/shirsha/yelp/user\")\nuser_df.createOrReplaceTempView(\"yelp_user\")\nprint(\"User data loaded.\")","user":"anonymous","dateUpdated":"2026-03-25T23:14:44+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TEXT","data":"Review data loaded. Total records: 6990280\nBusiness data loaded.\nUser data loaded.\n"}]},"apps":[],"runtimeInfos":{"jobUrl":{"propertyName":"jobUrl","label":"SPARK JOB","tooltip":"View in Spark web UI","group":"spark","values":[{"jobUrl":"http://node-master:4040/jobs/job?id=0"},{"jobUrl":"http://node-master:4040/jobs/job?id=1"},{"jobUrl":"http://node-master:4040/jobs/job?id=2"},{"jobUrl":"http://node-master:4040/jobs/job?id=3"},{"jobUrl":"http://node-master:4040/jobs/job?id=4"}],"interpreterSettingId":"spark"}},"progressUpdateIntervalMs":500,"jobName":"paragraph_1774450111735_491376245","id":"paragraph_1774450111735_491376245","dateCreated":"2026-03-25T22:48:31+0800","dateStarted":"2026-03-25T23:14:44+0800","dateFinished":"2026-03-25T23:41:33+0800","status":"FINISHED"},{"text":"%pyspark\n\nfrom pyspark.sql.functions import year, to_date, col, count, rank\nfrom pyspark.sql.window import Window\n\n# Get reviews per user per year\nuser_reviews_per_year = spark.table(\"yelp_review\") \\\n    .withColumn(\"year\", year(to_date(col(\"date\")))) \\\n    .groupBy(\"user_id\", \"year\") \\\n    .agg(count(\"*\").alias(\"num_reviews\"))\n\n# Rank users within each year by number of reviews\nwindow = Window.partitionBy(\"year\").orderBy(col(\"num_reviews\").desc())\nranked = user_reviews_per_year.withColumn(\"rank\", rank().over(window)) \\\n    .filter(col(\"rank\") <= 10) \\\n    .orderBy(\"year\", \"rank\")\n\nz.show(ranked)","user":"anonymous","dateUpdated":"2026-03-26T03:36:44+0800","progress":0,"config":{"colWidth":12,"fontSize":9,"results":{"0":{"graph":{"mode":"scatterChart","height":300,"optionOpen":false,"setting":{"multiBarChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","stacked":false},"lineChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","forceY":false,"lineWithFocus":false,"isDateFormat":false,"dateFormat":""},"stackedAreaChart":{"rotate":{"degree":"-45"},"xLabelStatus":"default","style":"stack"},"scatterChart":{}},"keys":[{"name":"user_id","index":0,"aggr":"sum"}],"groups":[],"values":[{"name":"year","index":1,"aggr":"sum"}]}}},"enabled":true,"editorSetting":{"language":"python","editOnDblClick":false,"completionKey":"TAB","completionSupport":true}},"settings":{"params":{},"forms":{}},"results":{"code":"SUCCESS","msg":[{"type":"TABLE","data":"user_id\tyear\tnum_reviews\trank\nn-lBS02-3yvlY5Q91mmwDA\t2005\t171\t1\n3MYdpmHeNwC6FquRWi3YOg\t2005\t60\t2\niUeZhkI0OK0BisakOkb3pQ\t2005\t51\t3\n58yhbFfNHjULDZx0FD-Dvw\t2005\t38\t4\n_BHTC7nyCBoZcfiiD5cOXg\t2005\t37\t5\njTXj5uf5ER5siDnQK_y4aA\t2005\t24\t6\n3xX-Et9I4Bi4wdRPWJkAFg\t2005\t19\t7\n-qoyKSF2G3PkR_7XNoJfpQ\t2005\t18\t8\nDOFamdMaC_hjn9zg3Gs-0w\t2005\t16\t9\nPO-U11FmTDiqCEqtilFjVQ\t2005\t15\t10\ngfQqQYI5_hCAGEHlHXIz2Q\t2006\t137\t1\nTDXV6AC5PYOZEyN9eeODfA\t2006\t107\t2\nnnImk681KaRqUVHlSfZjGQ\t2006\t78\t3\n3xX-Et9I4Bi4wdRPWJkAFg\t2006\t72\t4\ntiLm3eFfpxhwV6O9DEaneQ\t2006\t61\t5\nFfa1cXIvFAy8H1sorICaiQ\t2006\t50\t6\nfnBAgDX4D9mNgQZsjFCoog\t2006\t48\t7\n6OV_PFTl9RW2FmYQoOsuRQ\t2006\t46\t8\n_BHTC7nyCBoZcfiiD5cOXg\t2006\t45\t9\nRBXVFcXR3IjP0CYgmkSmtg\t2006\t42\t10\n0yYCMhDWCEIVUyZLzDWwqQ\t2007\t316\t1\n5aVByErCyBwi-cnx_iEJmg\t2007\t305\t2\n6O0MxTs3Pzzj5cXSHgYmrw\t2007\t264\t3\nbJ5FtCtZX3ZZacz2_2PJjA\t2007\t263\t4\nRdJ7Ykelg8w4y5FTmxjT8g\t2007\t228\t5\nTLcUXi2bn6v4hdB8X-M73w\t2007\t218\t6\nrjD5JDrDndu0vZvUhnnA7g\t2007\t198\t7\nkS1MQHYwIfD0462PE61IBw\t2007\t175\t8\ngpqGjIHlvUKDTttna4wcZQ\t